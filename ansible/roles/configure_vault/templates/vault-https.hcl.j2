ui = true

disable_mlock = {{ vault_disable_mlock | bool | lower }}

api_addr = "{{ vault_api_addr }}"
cluster_addr = "{{ vault_cluster_addr }}"

storage "file" {
  path = "{{ vault_data_dir }}"
}

listener "tcp" {
  address = "{{ vault_listener_address }}"
  cluster_address = "{{ vault_cluster_address }}"

  tls_disable = false
  tls_cert_file = "{{ vault_tls_dir }}/vault.crt"
  tls_key_file  = "{{ vault_tls_dir }}/vault.key"
}